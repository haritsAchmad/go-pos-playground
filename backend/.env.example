APP_NAME=Go POS Playground

APP_PORT=8080

# Generate a random value of at least 32 characters for production.
JWT_SECRET=change-this-to-a-long-random-secret
JWT_ISSUER=go-pos-playground
# Access token lifetime. The frontend refreshes an active session during its final 5 minutes.
JWT_EXPIRY_MINUTES=15

# Created only when no user exists. Remove the password after first startup.
INITIAL_ADMIN_NAME=Administrator
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me-now

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=pos_playground
DB_SCHEMA=go_pos_playground
DB_SSLMODE=disable
